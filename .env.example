# ============================================
# CHAT HAY - Environment Configuration
# ============================================

# API Backend
VITE_API_URL=http://localhost:8000
# Production: https://api.chathay.vn

# Environment
VITE_ENV=development
# Options: development | staging | production

# Sentry Error Tracking
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project
VITE_SENTRY_ENV=development

# LogRocket Session Replay
VITE_LOGROCKET_ID=your/logrocket/app/id

# Zalo Mini App Credentials
VITE_ZALO_APP_ID=your_zalo_app_id
VITE_ZALO_APP_SECRET=your_zalo_app_secret

# ZaloPay (Payment)
VITE_ZALOPAY_MERCHANT_ID=your_merchant_id
VITE_ZALOPAY_MERCHANT_NAME=CHATHAY

# Google Analytics 4
VITE_GA_ID=G-XXXXXXXXXX

# Mixpanel Analytics
VITE_MIXPANEL_TOKEN=your_mixpanel_token

# AI APIs (Backend uses these - not in frontend)
# These go in backend .env, not frontend:
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=

# Database (Backend)
# DATABASE_URL=postgresql://...
# JWT_SECRET=your_jwt_secret

# Redis (optional, for caching)
# REDIS_URL=redis://localhost:6379

# ============================================
# Notes:
# - Copy this file to .env.local for development
# - .env.local is gitignored (contains secrets)
# - Only VITE_* prefixed vars are exposed to frontend
# - Backend vars should NOT be in this file
# ============================================
