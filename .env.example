# === TELEGRAM BOT ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# === AI - Google Gemini (Free: 1500 req/day PER PROJECT) ===
# Key chinh (bat buoc): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Key phu (tuy chon): tao them project moi de nhan doi quota mien phi
# Vao aistudio.google.com/apikey → "Create API key in new project"
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# === TTS - FPT.AI ===
FPT_AI_API_KEY=your_fpt_ai_api_key_here
FPT_AI_VOICE=banmai
# Voices: banmai (Nữ Bắc), leminh (Nam Bắc), thuminh (Nữ Bắc trẻ), 
#          giahuy (Nam Trung), myan (Nữ Trung), lannhi (Nữ Nam)

# === SUPABASE ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# === SERVER ===
PORT=8000
HOST=0.0.0.0
DEBUG=true

# === LIMITS ===
FREE_DAILY_LIMIT=5
MAX_FILE_SIZE_MB=10
MAX_PAGES=20

# === ZALO OA (khi OA duoc duyet) ===
# Lay token tai: https://developers.zalo.me/
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_SECRET=
